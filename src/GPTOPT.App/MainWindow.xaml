<Window x:Class="GPTOPT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPTOPT Gaming Assistant" Width="1240" Height="820"
        MinWidth="1040" MinHeight="680" WindowStartupLocation="CenterScreen"
        Background="#0E1117" Foreground="#F3F6FA">
  <Grid Margin="18">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

    <DockPanel Grid.Row="0" Margin="0,0,0,16">
      <StackPanel DockPanel.Dock="Left">
        <TextBlock Text="GPTOPT" FontSize="30" FontWeight="Bold"/>
        <TextBlock Text="Understand, choose, apply and verify PC gaming changes" Foreground="#9CA8B8"/>
      </StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="LocalAuditButton" Content="Run Local Audit" Click="LocalAuditButton_Click" Margin="4" Padding="14,8"/>
        <Button x:Name="PublishAuditButton" Content="Run + Publish" Click="PublishAuditButton_Click" Margin="4" Padding="14,8"/>
        <Button Content="Refresh" Click="RefreshButton_Click" Margin="4" Padding="14,8"/>
      </StackPanel>
    </DockPanel>

    <TabControl Grid.Row="1" Background="#121720" BorderThickness="0">
      <TabItem Header="Optimize">
        <Grid Margin="16">
          <Grid.ColumnDefinitions><ColumnDefinition Width="430"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

          <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,12">
            <TextBlock Text="Recommended actions" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Select only changes you understand. GPTOPT shows the current state, target, expected impact, risk, exact method and reboot requirement before applying anything." Foreground="#AEB8C5" TextWrapping="Wrap" Margin="0,5,0,0"/>
          </StackPanel>

          <ListBox x:Name="RecommendationList" Grid.Row="1" Grid.Column="0" Background="#0B0E13" Foreground="White" SelectionChanged="RecommendationList_SelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="#2B3442" BorderThickness="0,0,0,1" Padding="8">
                  <StackPanel>
                    <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding CanApply}" Content="{Binding Summary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Category}" Foreground="#7EB6FF" FontSize="11" Margin="22,3,0,0"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="18,0,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
              <TextBlock x:Name="RecommendationTitle" Text="Select a recommendation" FontSize="24" FontWeight="Bold"/>
              <TextBlock x:Name="RecommendationMeta" Foreground="#7EB6FF" Margin="0,5,0,14"/>
              <TextBlock Text="Current state" FontWeight="Bold"/>
              <TextBlock x:Name="CurrentStateText" TextWrapping="Wrap" Margin="0,4,0,12" Foreground="#D3DAE3"/>
              <TextBlock Text="Target state" FontWeight="Bold"/>
              <TextBlock x:Name="TargetStateText" TextWrapping="Wrap" Margin="0,4,0,12" Foreground="#D3DAE3"/>
              <TextBlock Text="Why this matters" FontWeight="Bold"/>
              <TextBlock x:Name="WhyText" TextWrapping="Wrap" Margin="0,4,0,12" Foreground="#D3DAE3"/>
              <TextBlock Text="What GPTOPT will do" FontWeight="Bold"/>
              <TextBlock x:Name="HowText" TextWrapping="Wrap" Margin="0,4,0,12" Foreground="#D3DAE3"/>
              <Border Background="#191F29" CornerRadius="5" Padding="10">
                <TextBlock x:Name="SafetyText" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="Select Safe Defaults" Click="SelectSafeDefaults_Click" Padding="14,8" Margin="0,0,8,0"/>
            <Button Content="Clear Selection" Click="ClearSelection_Click" Padding="14,8" Margin="0,0,8,0"/>
            <Button x:Name="ApplySelectedButton" Content="Apply Selected" Click="ApplySelected_Click" Padding="18,8"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Dashboard">
        <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="16">
          <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <GroupBox Header="Platform" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><TextBlock x:Name="PlatformText" Margin="14" FontFamily="Consolas" TextWrapping="Wrap"/></GroupBox>
          <GroupBox Header="Gaming Configuration" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8"><TextBlock x:Name="GamingText" Margin="14" FontFamily="Consolas" TextWrapping="Wrap"/></GroupBox>
          <GroupBox Header="Devices and Running Tools" Grid.Row="1" Grid.Column="0" Margin="0,8,8,0"><TextBlock x:Name="DeviceText" Margin="14" FontFamily="Consolas" TextWrapping="Wrap"/></GroupBox>
          <GroupBox Header="Health Signals" Grid.Row="1" Grid.Column="1" Margin="8,8,0,0"><TextBlock x:Name="HealthText" Margin="14" FontFamily="Consolas" TextWrapping="Wrap"/></GroupBox>
        </Grid></ScrollViewer>
      </TabItem>

      <TabItem Header="Audit History">
        <Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="320"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <ListBox x:Name="HistoryList" Grid.Column="0" Background="#0B0E13" Foreground="White"/>
          <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="Persistent local audit store" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="AuditIdText" Margin="0,8,0,12" Foreground="#9CA8B8"/>
            <Button Content="Open Audit Store" HorizontalAlignment="Left" Click="OpenAuditStore_Click"/>
            <TextBlock Text="Raw diagnostic detail remains local. Only the sanitized report is published to GitHub." TextWrapping="Wrap" Foreground="#9CA8B8" Margin="0,12,0,0"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Performance Capture">
        <StackPanel Margin="20">
          <TextBlock Text="Performance capture" FontSize="24" FontWeight="Bold"/>
          <TextBlock Text="PresentMon integration will compare frame-time stability and latency before and after selected changes. This prevents GPTOPT from claiming an optimization worked without measurement." TextWrapping="Wrap" Foreground="#B8C1CC" Margin="0,10,0,18"/>
          <Button Content="Open PresentMon" Width="180" HorizontalAlignment="Left" Click="OpenPresentMon_Click"/>
        </StackPanel>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2" Background="#171A20" CornerRadius="6" Padding="12" Margin="0,14,0,0">
      <StackPanel><ProgressBar x:Name="AuditProgress" Height="7" Minimum="0" Maximum="100"/><TextBlock x:Name="StatusText" Text="Ready" Margin="0,7,0,0" Foreground="#B8C1CC" TextWrapping="Wrap"/></StackPanel>
    </Border>
  </Grid>
</Window>
