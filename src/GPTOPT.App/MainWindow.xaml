<Window x:Class="GPTOPT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPTOPT" Width="1440" Height="920"
        MinWidth="1180" MinHeight="760" WindowStartupLocation="CenterScreen"
        Background="#07090E" Foreground="#F6F8FB" FontFamily="Segoe UI">
  <Window.Resources>
    <SolidColorBrush x:Key="Page" Color="#07090E"/>
    <SolidColorBrush x:Key="Rail" Color="#0B1018"/>
    <SolidColorBrush x:Key="Panel" Color="#101722"/>
    <SolidColorBrush x:Key="Panel2" Color="#141E2C"/>
    <SolidColorBrush x:Key="Stroke" Color="#26364A"/>
    <SolidColorBrush x:Key="Muted" Color="#91A0B5"/>
    <SolidColorBrush x:Key="Blue" Color="#4C9DFF"/>
    <SolidColorBrush x:Key="Green" Color="#58D99D"/>
    <SolidColorBrush x:Key="Amber" Color="#FFBE55"/>
    <SolidColorBrush x:Key="Red" Color="#FF717B"/>

    <Style TargetType="Button">
      <Setter Property="Background" Value="#182538"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#30465F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="15,10"/>
      <Setter Property="Margin" Value="4"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="MinHeight" Value="40"/>
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#1769C5"/>
      <Setter Property="BorderBrush" Value="#62ADFF"/>
    </Style>
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#42202A"/>
      <Setter Property="BorderBrush" Value="#7E3846"/>
    </Style>
    <Style x:Key="ActionCard" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{StaticResource Panel2}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
      <Setter Property="Padding" Value="18"/>
      <Setter Property="MinHeight" Value="132"/>
    </Style>
    <Style TargetType="TabControl">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="#B8C4D3"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Padding" Value="16,13"/>
      <Setter Property="Margin" Value="4,2"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style TargetType="GroupBox">
      <Setter Property="Background" Value="{StaticResource Panel}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
      <Setter Property="Padding" Value="12"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="235"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Column="0" Grid.RowSpan="2" Background="{StaticResource Rail}" BorderBrush="#1C293A" BorderThickness="0,0,1,0">
      <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="5,6,5,20">
          <TextBlock Text="GPTOPT" FontSize="30" FontWeight="Bold"/>
          <TextBlock Text="HALO PERFORMANCE ASSISTANT" Foreground="#73B8FF" FontSize="10" FontWeight="Bold" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#0A111B" CornerRadius="12" Padding="14" Margin="0,0,0,18" BorderBrush="#1C2D42" BorderThickness="1">
          <StackPanel>
            <TextBlock Text="SESSION READINESS" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/>
            <TextBlock x:Name="HealthGradeText" Text="--" FontSize="46" FontWeight="Bold" Foreground="{StaticResource Green}" Margin="0,4,0,0"/>
            <TextBlock x:Name="HealthSummaryText" Text="Scan the PC to calculate readiness" Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <StackPanel Grid.Row="3">
          <TextBlock Text="LATEST SCAN" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/>
          <TextBlock x:Name="AuditIdText" Text="No audit loaded" TextWrapping="Wrap" Margin="0,6,0,12"/>
          <Button Content="Scan PC" Click="LocalAuditButton_Click" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"/>
          <Button Content="Scan + Publish" Click="PublishAuditButton_Click" HorizontalAlignment="Stretch"/>
          <Button Content="Rollback" Click="OpenRollbackManager_Click" HorizontalAlignment="Stretch" Style="{StaticResource DangerButton}"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Grid.Row="0">
      <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
      <Border Grid.Row="0" Background="#0A0F17" BorderBrush="#1D2A3B" BorderThickness="0,0,0,1" Padding="24,16">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="Gaming control without mystery tweaks" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Prepare the session, diagnose real faults, and keep only changes that prove themselves." Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="LocalAuditButton" Content="Quick Scan" Click="LocalAuditButton_Click" Style="{StaticResource PrimaryButton}"/>
            <Button x:Name="PublishAuditButton" Content="Publish Latest" Click="PublishAuditButton_Click"/>
            <Button Content="Refresh" Click="RefreshButton_Click"/>
          </StackPanel>
        </Grid>
      </Border>

      <TabControl Grid.Row="1" TabStripPlacement="Left" Margin="0" Background="{StaticResource Page}">
        <TabItem Header="Home">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="26">
              <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="Your next Halo session" FontSize="31" FontWeight="Bold"/>
                  <TextBlock Text="Start here. GPTOPT will surface only what deserves attention." Foreground="{StaticResource Muted}" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Run Session Check" Click="RunTargetedDiagnostics_Click" Style="{StaticResource PrimaryButton}" Padding="24,12"/>
              </Grid>

              <UniformGrid Columns="3" Margin="0,0,0,20">
                <Button Style="{StaticResource ActionCard}" Click="RunTargetedDiagnostics_Click">
                  <StackPanel><TextBlock Text="01  HEALTH" Foreground="#73B8FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="Find what is actually wrong" FontSize="19" FontWeight="Bold" Margin="0,8,0,5"/><TextBlock Text="Problem devices, WHEA, NVIDIA resets, storage stalls, USB faults, crashes, and reboot sources." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel>
                </Button>
                <Button Style="{StaticResource ActionCard}" Click="OpenControllerCalibration_Click">
                  <StackPanel><TextBlock Text="02  CONTROLLER" Foreground="#B4A1FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="Validate the Vader 4 Pro" FontSize="19" FontWeight="Bold" Margin="0,8,0,5"/><TextBlock Text="Check centering, range, button response, and the Windows controller path without replacing Flydigi tuning." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel>
                </Button>
                <Button Style="{StaticResource ActionCard}" Click="CompareCaptures_Click">
                  <StackPanel><TextBlock Text="03  PERFORMANCE" Foreground="#67DCA4" FontSize="10" FontWeight="Bold"/><TextBlock Text="Prove a change helped" FontSize="19" FontWeight="Bold" Margin="0,8,0,5"/><TextBlock Text="Compare before and after CapFrameX or PresentMon captures and get a keep, rollback, or inconclusive result." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel>
                </Button>
              </UniformGrid>

              <TextBlock Text="Current machine" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <GroupBox Header="Hardware and display" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><TextBlock x:Name="PlatformText" Margin="8" TextWrapping="Wrap"/></GroupBox>
                <GroupBox Header="Gaming baseline" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8"><TextBlock x:Name="GamingText" Margin="8" TextWrapping="Wrap"/></GroupBox>
                <GroupBox Header="Controller, network, tools" Grid.Row="1" Grid.Column="0" Margin="0,8,8,0"><TextBlock x:Name="DeviceText" Margin="8" TextWrapping="Wrap"/></GroupBox>
                <GroupBox Header="What needs attention" Grid.Row="1" Grid.Column="1" Margin="8,8,0,0"><TextBlock x:Name="HealthText" Margin="8" TextWrapping="Wrap"/></GroupBox>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Prepare">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28">
              <TextBlock Text="Prepare for Halo" FontSize="31" FontWeight="Bold"/>
              <TextBlock Text="A fast pre-session checklist that checks the path you actually use." Foreground="{StaticResource Muted}" Margin="0,5,0,20"/>
              <UniformGrid Columns="2">
                <Border Background="{StaticResource Panel}" CornerRadius="12" Padding="18" Margin="5" BorderBrush="{StaticResource Stroke}" BorderThickness="1"><StackPanel><TextBlock Text="SYSTEM CHECK" Foreground="#73B8FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="Scan Windows and hardware" FontSize="20" FontWeight="Bold" Margin="0,7,0,5"/><TextBlock Text="Refresh the current state, health score, drivers, display mode, gaming settings, devices, and pending servicing." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"/><Button Content="Run Full Scan" Click="LocalAuditButton_Click" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/></StackPanel></Border>
                <Border Background="{StaticResource Panel}" CornerRadius="12" Padding="18" Margin="5" BorderBrush="{StaticResource Stroke}" BorderThickness="1"><StackPanel><TextBlock Text="FAULT CHECK" Foreground="#FFBE55" FontSize="10" FontWeight="Bold"/><TextBlock Text="Inspect errors that can cause hitches" FontSize="20" FontWeight="Bold" Margin="0,7,0,5"/><TextBlock Text="Classify recent WHEA, GPU reset, storage, USB, controller, and application crash events instead of counting them blindly." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"/><Button Content="Run Targeted Diagnostics" Click="RunTargetedDiagnostics_Click" HorizontalAlignment="Left"/></StackPanel></Border>
                <Border Background="{StaticResource Panel}" CornerRadius="12" Padding="18" Margin="5" BorderBrush="{StaticResource Stroke}" BorderThickness="1"><StackPanel><TextBlock Text="INPUT CHECK" Foreground="#B4A1FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="Test the controller path" FontSize="20" FontWeight="Bold" Margin="0,7,0,5"/><TextBlock Text="Verify that Windows sees the wired Vader 4 Pro correctly. Keep Flydigi SpaceStation and GameControllerService running." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"/><Button Content="Open Controller Test" Click="OpenControllerCalibration_Click" HorizontalAlignment="Left"/></StackPanel></Border>
                <Border Background="{StaticResource Panel}" CornerRadius="12" Padding="18" Margin="5" BorderBrush="{StaticResource Stroke}" BorderThickness="1"><StackPanel><TextBlock Text="VERIFY" Foreground="#67DCA4" FontSize="10" FontWeight="Bold"/><TextBlock Text="Confirm the current state" FontSize="20" FontWeight="Bold" Margin="0,7,0,5"/><TextBlock Text="Run a fresh local audit after applying or rolling back changes. GPTOPT will not assume the requested state actually took effect." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"/><Button Content="Verify Current State" Click="VerifyChanges_Click" HorizontalAlignment="Left"/></StackPanel></Border>
              </UniformGrid>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Controller">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28">
              <TextBlock Text="Controller" FontSize="31" FontWeight="Bold"/>
              <TextBlock Text="Flydigi Vader 4 Pro wired path. GPTOPT does not kill or replace SpaceStation." Foreground="{StaticResource Muted}" Margin="0,5,0,20"/>
              <Border Background="{StaticResource Panel}" CornerRadius="13" Padding="22" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="WINDOWS INPUT TEST" Foreground="#B4A1FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="Check stick centers, full range, triggers, and buttons" FontSize="22" FontWeight="Bold" Margin="0,7,0,6"/><TextBlock Text="Use this to identify drift, asymmetrical range, missed buttons, or an incorrect Windows controller mapping. Make SpaceStation curve and deadzone changes there—not here." Foreground="{StaticResource Muted}" TextWrapping="Wrap" MaxWidth="720"/></StackPanel><Button Grid.Column="1" Content="Open joy.cpl" Click="OpenControllerCalibration_Click" Style="{StaticResource PrimaryButton}" VerticalAlignment="Center" Padding="22,12"/></Grid>
              </Border>
              <Border Background="#0D1520" CornerRadius="11" Padding="16" Margin="0,16,0,0"><StackPanel><TextBlock Text="Known GPTOPT controller rules" FontSize="18" FontWeight="Bold"/><TextBlock Text="• Wired connection preferred&#10;• Keep Flydigi SpaceStation and GameControllerService running&#10;• Do not add smoothing or look acceleration without measurement&#10;• Calibrate hardware first; tune Halo second" Foreground="#C7D1DE" Margin="0,8,0,0"/></StackPanel></Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Performance">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28">
              <TextBlock Text="Performance proof" FontSize="31" FontWeight="Bold"/>
              <TextBlock Text="A tweak is not an improvement until equivalent runs show it." Foreground="{StaticResource Muted}" Margin="0,5,0,20"/>
              <UniformGrid Columns="2">
                <Button Style="{StaticResource ActionCard}" Click="CompareCaptures_Click"><StackPanel><TextBlock Text="COMPARE RUNS" Foreground="#67DCA4" FontSize="10" FontWeight="Bold"/><TextBlock Text="Before vs. after" FontSize="21" FontWeight="Bold" Margin="0,8,0,5"/><TextBlock Text="Select two CSV captures. GPTOPT compares average FPS, 1% low, mean frame time, P95, P99, and variance, then issues a verdict." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel></Button>
                <Button Style="{StaticResource ActionCard}" Click="OpenPresentMon_Click"><StackPanel><TextBlock Text="CAPTURE" Foreground="#73B8FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="Open PresentMon" FontSize="21" FontWeight="Bold" Margin="0,8,0,5"/><TextBlock Text="Use the measurement layer to collect repeatable frame-time and latency evidence instead of relying on feel alone." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel></Button>
              </UniformGrid>
              <Border Background="#0D1520" CornerRadius="11" Padding="16" Margin="5,16,5,0"><TextBlock Text="Keep a change only when repeated, equivalent runs improve frame-time consistency, latency, stability, or input behavior. Mixed results are inconclusive—not a win." Foreground="#CBD5E1" TextWrapping="Wrap"/></Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Troubleshoot">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28">
              <TextBlock Text="Troubleshoot by symptom" FontSize="31" FontWeight="Bold"/>
              <TextBlock Text="Start with the symptom, then open the focused evidence source." Foreground="{StaticResource Muted}" Margin="0,5,0,18"/>
              <UniformGrid Columns="3">
                <Button Style="{StaticResource ActionCard}" Click="RunTargetedDiagnostics_Click"><StackPanel><TextBlock Text="STUTTER / HITCH" FontSize="18" FontWeight="Bold"/><TextBlock Text="Check WHEA, display resets, storage timeouts, USB faults, and application crashes." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,7,0,0"/></StackPanel></Button>
                <Button Style="{StaticResource ActionCard}" Click="OpenControllerCalibration_Click"><StackPanel><TextBlock Text="INPUT FEELS WRONG" FontSize="18" FontWeight="Bold"/><TextBlock Text="Verify hardware centers and range before touching Halo or Flydigi curves." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,7,0,0"/></StackPanel></Button>
                <Button Style="{StaticResource ActionCard}" Click="OpenEventViewer_Click"><StackPanel><TextBlock Text="CRASH / DRIVER RESET" FontSize="18" FontWeight="Bold"/><TextBlock Text="Open Event Viewer after GPTOPT classifies the likely category and affected provider." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,7,0,0"/></StackPanel></Button>
              </UniformGrid>
              <TextBlock Text="Focused tools" FontSize="20" FontWeight="Bold" Margin="4,22,0,8"/>
              <WrapPanel><Button Content="Task Manager" Width="165" Click="OpenTaskManager_Click"/><Button Content="Device Manager" Width="165" Click="OpenDeviceManager_Click"/><Button Content="Event Viewer" Width="165" Click="OpenEventViewer_Click"/><Button Content="Windows Update" Width="165" Click="OpenWindowsUpdate_Click"/><Button Content="NVIDIA App" Width="165" Click="OpenNvidiaApp_Click"/><Button Content="PresentMon" Width="165" Click="OpenPresentMon_Click"/></WrapPanel>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Advanced Tune">
          <Grid Margin="22">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="455"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Advanced tuning" FontSize="29" FontWeight="Bold"/><TextBlock Text="Exact Windows controls. Already-correct values stay visible so the workflow never appears dead." Foreground="{StaticResource Muted}" Margin="0,5,0,0"/></StackPanel><ComboBox x:Name="CategoryFilter" Grid.Column="1" Width="170" VerticalAlignment="Bottom" SelectionChanged="CategoryFilter_SelectionChanged"><ComboBoxItem Content="All" IsSelected="True"/><ComboBoxItem Content="Windows Gaming"/><ComboBoxItem Content="Graphics"/><ComboBoxItem Content="Health"/><ComboBoxItem Content="Devices"/></ComboBox></Grid>
            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#0D1724" CornerRadius="9" Padding="10" Margin="0,0,0,12"><StackPanel Orientation="Horizontal"><TextBlock Text="PROFILES" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="4,0,10,0"/><Button Content="Safe Gaming Baseline" Click="SafeGamingProfile_Click"/><Button Content="Stability Review" Click="StabilityProfile_Click"/><Button Content="Clear" Click="ClearSelection_Click"/></StackPanel></Border>
            <Border Grid.Row="2" Grid.Column="0" Background="#090E16" CornerRadius="9" BorderBrush="{StaticResource Stroke}" BorderThickness="1"><ListBox x:Name="RecommendationList" Background="Transparent" Foreground="White" BorderThickness="0" SelectionChanged="RecommendationList_SelectionChanged"><ListBox.ItemTemplate><DataTemplate><Border BorderBrush="#223149" BorderThickness="0,0,0,1" Padding="13"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" IsEnabled="{Binding CanApply}" VerticalAlignment="Top" Margin="0,4,11,0" Click="RecommendationCheckBox_Click"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap"/><TextBlock Text="{Binding Summary}" Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></Border>
            <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource Panel2}" CornerRadius="9" Padding="20" Margin="16,0,0,0" BorderBrush="{StaticResource Stroke}" BorderThickness="1"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel><TextBlock x:Name="RecommendationTitle" Text="Select a setting or finding" FontSize="25" FontWeight="Bold" TextWrapping="Wrap"/><TextBlock x:Name="RecommendationMeta" Foreground="#7EB8FF" Margin="0,6,0,16"/><Grid Margin="0,0,0,14"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Border Grid.Column="0" Background="#0C131D" CornerRadius="7" Padding="12" Margin="0,0,7,0"><StackPanel><TextBlock Text="CURRENT" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="CurrentStateText" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border><Border Grid.Column="1" Background="#0D2119" CornerRadius="7" Padding="12" Margin="7,0,0,0"><StackPanel><TextBlock Text="TARGET" Foreground="{StaticResource Green}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="TargetStateText" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border></Grid><TextBlock Text="WHY" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="WhyText" TextWrapping="Wrap" Margin="0,5,0,16"/><TextBlock Text="WHAT GPTOPT DOES" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="HowText" TextWrapping="Wrap" Margin="0,5,0,16"/><Border Background="#0C131D" CornerRadius="7" Padding="12"><TextBlock x:Name="SafetyText" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer></Border>
            <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="SelectionCountText" Text="0 selected" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/><Button x:Name="ApplySelectedButton" Grid.Column="1" Content="Review &amp; Apply" Click="ApplySelected_Click" Style="{StaticResource PrimaryButton}" Padding="22,11"/></Grid>
          </Grid>
        </TabItem>

        <TabItem Header="History">
          <Grid Margin="24"><Grid.ColumnDefinitions><ColumnDefinition Width="390"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><ListBox x:Name="HistoryList" Grid.Column="0" Background="#090E16" Foreground="White" BorderBrush="{StaticResource Stroke}" MouseDoubleClick="HistoryList_MouseDoubleClick"/><StackPanel Grid.Column="1" Margin="24,0,0,0"><TextBlock Text="Audit and rollback history" FontSize="29" FontWeight="Bold"/><TextBlock Text="Double-click an audit to open its private local folder. Published summaries can lag until Scan + Publish is used." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,8,0,18"/><Button Content="Open Audit Store" HorizontalAlignment="Left" Click="OpenAuditStore_Click"/><Button Content="Rollback Manager" HorizontalAlignment="Left" Click="OpenRollbackManager_Click" Style="{StaticResource DangerButton}"/></StackPanel></Grid>
        </TabItem>
      </TabControl>
    </Grid>

    <Border Grid.Column="1" Grid.Row="1" Background="#0A0F17" BorderBrush="#1D2A3B" BorderThickness="0,1,0,0" Padding="18,11">
      <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="250"/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="StatusText" Text="Ready" Foreground="#CBD4DF" TextWrapping="Wrap"/><TextBlock x:Name="StatusDetailText" Text="No task running" Foreground="#68798F" FontSize="11" Margin="0,3,0,0"/></StackPanel><ProgressBar x:Name="AuditProgress" Grid.Column="1" Height="8" Minimum="0" Maximum="100" VerticalAlignment="Center"/></Grid>
    </Border>
  </Grid>
</Window>