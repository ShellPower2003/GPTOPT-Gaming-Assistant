<Window x:Class="GPTOPT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPTOPT Gaming Assistant" Width="1180" Height="760"
        MinWidth="980" MinHeight="620" WindowStartupLocation="CenterScreen"
        Background="#0E1117" Foreground="#F3F6FA">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" Margin="0,0,0,16">
      <StackPanel DockPanel.Dock="Left">
        <TextBlock Text="GPTOPT" FontSize="30" FontWeight="Bold"/>
        <TextBlock Text="Native PC gaming diagnostics and optimization control center" Foreground="#9CA8B8"/>
      </StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="LocalAuditButton" Content="Run Local Audit" Click="LocalAuditButton_Click"/>
        <Button x:Name="PublishAuditButton" Content="Run + Publish" Click="PublishAuditButton_Click"/>
        <Button Content="Refresh" Click="RefreshButton_Click"/>
      </StackPanel>
    </DockPanel>

    <TabControl Grid.Row="1" Background="#121720" BorderThickness="0">
      <TabItem Header="Dashboard">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <Grid Margin="16">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

            <GroupBox Header="Platform" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Background="{StaticResource CardBrush}" Foreground="White">
              <TextBlock x:Name="PlatformText" Margin="14" FontFamily="Consolas" TextWrapping="Wrap"/>
            </GroupBox>
            <GroupBox Header="Gaming Configuration" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" Background="{StaticResource CardBrush}" Foreground="White">
              <TextBlock x:Name="GamingText" Margin="14" FontFamily="Consolas" TextWrapping="Wrap"/>
            </GroupBox>
            <GroupBox Header="Devices and Running Tools" Grid.Row="1" Grid.Column="0" Margin="0,8,8,0" Background="{StaticResource CardBrush}" Foreground="White">
              <TextBlock x:Name="DeviceText" Margin="14" FontFamily="Consolas" TextWrapping="Wrap"/>
            </GroupBox>
            <GroupBox Header="Health Signals" Grid.Row="1" Grid.Column="1" Margin="8,8,0,0" Background="{StaticResource CardBrush}" Foreground="White">
              <TextBlock x:Name="HealthText" Margin="14" FontFamily="Consolas" TextWrapping="Wrap"/>
            </GroupBox>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Audit History">
        <Grid Margin="16">
          <Grid.ColumnDefinitions><ColumnDefinition Width="320"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <ListBox x:Name="HistoryList" Grid.Column="0" Background="#0B0E13" Foreground="White"/>
          <StackPanel Grid.Column="1" Margin="18,0,0,0">
            <TextBlock Text="Persistent local audit store" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="AuditIdText" Margin="0,8,0,12" Foreground="#9CA8B8"/>
            <Button Content="Open Audit Store" HorizontalAlignment="Left" Click="OpenAuditStore_Click"/>
            <TextBlock Text="Raw diagnostic detail remains local. Only the sanitized report is published to GitHub." TextWrapping="Wrap" Foreground="#9CA8B8" Margin="0,12,0,0"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Performance Capture">
        <StackPanel Margin="20">
          <TextBlock Text="Performance capture integration" FontSize="24" FontWeight="Bold"/>
          <TextBlock Text="PresentMon service/API integration is the next data provider. It will supply frame times, CPU/GPU/display latency, utilization, temperature and power telemetry without requiring GPTOPT to reinvent ETW collection." TextWrapping="Wrap" Foreground="#B8C1CC" Margin="0,10,0,18"/>
          <Button Content="Open PresentMon" Width="180" HorizontalAlignment="Left" Click="OpenPresentMon_Click"/>
        </StackPanel>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2" Background="#171A20" CornerRadius="6" Padding="12" Margin="0,14,0,0">
      <StackPanel>
        <ProgressBar x:Name="AuditProgress" Height="7" Minimum="0" Maximum="100"/>
        <TextBlock x:Name="StatusText" Text="Ready" Margin="0,7,0,0" Foreground="#B8C1CC"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
