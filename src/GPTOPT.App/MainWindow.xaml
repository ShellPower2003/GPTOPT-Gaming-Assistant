<Window x:Class="GPTOPT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPTOPT Gaming Assistant" Width="1380" Height="900"
        MinWidth="1160" MinHeight="740" WindowStartupLocation="CenterScreen"
        Background="#070A10" Foreground="#F4F7FB" FontFamily="Segoe UI">
  <Window.Resources>
    <SolidColorBrush x:Key="Surface" Color="#0E141F"/>
    <SolidColorBrush x:Key="Surface2" Color="#131C2A"/>
    <SolidColorBrush x:Key="Stroke" Color="#26364E"/>
    <SolidColorBrush x:Key="Muted" Color="#8D9BB0"/>
    <SolidColorBrush x:Key="Blue" Color="#4F9CFF"/>
    <SolidColorBrush x:Key="Green" Color="#54D69A"/>
    <SolidColorBrush x:Key="Amber" Color="#FFBF5A"/>

    <Style TargetType="Button">
      <Setter Property="Background" Value="#18263A"/><Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#304763"/><Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="15,10"/><Setter Property="Margin" Value="4"/>
      <Setter Property="Cursor" Value="Hand"/><Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#1769C2"/><Setter Property="BorderBrush" Value="#63A9F5"/>
    </Style>
    <Style x:Key="CardButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Padding" Value="18"/>
      <Setter Property="Background" Value="{StaticResource Surface2}"/><Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
    </Style>
    <Style TargetType="TabItem"><Setter Property="Foreground" Value="#BFC9D7"/><Setter Property="Padding" Value="20,12"/></Style>
    <Style TargetType="GroupBox"><Setter Property="Background" Value="{StaticResource Surface2}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="{StaticResource Stroke}"/><Setter Property="Padding" Value="12"/></Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#0B111B" BorderBrush="#1C2A3C" BorderThickness="0,0,0,1" Padding="24,17">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="GPTOPT" FontSize="30" FontWeight="Bold"/>
            <Border Background="#12365E" CornerRadius="12" Padding="9,3" Margin="12,5,0,0"><TextBlock Text="GAMING CONTROL CENTER" Foreground="#8FC6FF" FontSize="10" FontWeight="Bold"/></Border>
          </StackPanel>
          <TextBlock Text="Prepare the session. Fix real problems. Prove whether changes helped." Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="LocalAuditButton" Content="Scan PC" Click="LocalAuditButton_Click" Style="{StaticResource PrimaryButton}"/>
          <Button x:Name="PublishAuditButton" Content="Scan + Publish" Click="PublishAuditButton_Click"/>
          <Button Content="Refresh" Click="RefreshButton_Click"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="18">
      <Grid.ColumnDefinitions><ColumnDefinition Width="265"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource Surface}" CornerRadius="12" Padding="17" Margin="0,0,16,0" BorderBrush="#1E2C40" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="READINESS" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold"/>
          <Border Background="#0A1019" CornerRadius="10" Padding="15" Margin="0,10,0,16">
            <StackPanel>
              <TextBlock x:Name="HealthGradeText" Text="--" FontSize="44" FontWeight="Bold" Foreground="{StaticResource Green}"/>
              <TextBlock x:Name="HealthSummaryText" Text="Run a scan to calculate readiness" Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <TextBlock Text="LATEST SCAN" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold"/>
          <TextBlock x:Name="AuditIdText" Text="No audit loaded" TextWrapping="Wrap" Margin="0,8,0,16"/>

          <Button Content="Verify Current State" Click="VerifyChanges_Click" HorizontalAlignment="Stretch"/>
          <Button Content="Rollback Changes" Click="OpenRollbackManager_Click" HorizontalAlignment="Stretch"/>
          <Button Content="Open Audit Files" Click="OpenAuditStore_Click" HorizontalAlignment="Stretch"/>

          <Border Background="#111D2C" CornerRadius="9" Padding="12" Margin="4,18,4,0">
            <StackPanel>
              <TextBlock Text="GPTOPT RULE" Foreground="#7EB8FF" FontSize="10" FontWeight="Bold"/>
              <TextBlock Text="No mystery tweaks. Every change gets an explanation, rollback, and verification path." Foreground="#BFC9D7" TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <TabControl Grid.Column="1" Background="{StaticResource Surface}" BorderThickness="0">
        <TabItem Header="Home">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="Ready for a session?" FontSize="28" FontWeight="Bold"/>
                  <TextBlock Text="Use the fast path below. Advanced tuning stays out of the way until you need it." Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Run Full Scan" Click="LocalAuditButton_Click" Style="{StaticResource PrimaryButton}" Padding="22,12"/>
              </Grid>

              <UniformGrid Columns="3" Margin="0,0,0,18">
                <Button Style="{StaticResource CardButton}" Click="RunTargetedDiagnostics_Click">
                  <StackPanel><TextBlock Text="DIAGNOSE" Foreground="#7EB8FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="Find the actual problem" FontSize="18" FontWeight="Bold" Margin="0,5,0,4"/><TextBlock Text="Classify device faults, WHEA, GPU resets, storage, USB, crashes, and pending reboot sources." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel>
                </Button>
                <Button Style="{StaticResource CardButton}" Click="OpenControllerCalibration_Click">
                  <StackPanel><TextBlock Text="CONTROLLER" Foreground="#A899FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="Check stick behavior" FontSize="18" FontWeight="Bold" Margin="0,5,0,4"/><TextBlock Text="Open Windows game-controller testing while preserving Flydigi SpaceStation tuning." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel>
                </Button>
                <Button Style="{StaticResource CardButton}" Click="CompareCaptures_Click">
                  <StackPanel><TextBlock Text="VERIFY" Foreground="#62D6A0" FontSize="10" FontWeight="Bold"/><TextBlock Text="Compare performance" FontSize="18" FontWeight="Bold" Margin="0,5,0,4"/><TextBlock Text="Compare before and after CapFrameX or PresentMon CSV captures before keeping a tweak." Foreground="{StaticResource Muted}" TextWrapping="Wrap"/></StackPanel>
                </Button>
              </UniformGrid>

              <TextBlock Text="Current system" FontSize="21" FontWeight="Bold" Margin="0,0,0,10"/>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <GroupBox Header="Hardware" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><TextBlock x:Name="PlatformText" Margin="8" TextWrapping="Wrap"/></GroupBox>
                <GroupBox Header="Gaming baseline" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8"><TextBlock x:Name="GamingText" Margin="8" TextWrapping="Wrap"/></GroupBox>
                <GroupBox Header="Controller, network, tools" Grid.Row="1" Grid.Column="0" Margin="0,8,8,0"><TextBlock x:Name="DeviceText" Margin="8" TextWrapping="Wrap"/></GroupBox>
                <GroupBox Header="Needs attention" Grid.Row="1" Grid.Column="1" Margin="8,8,0,0"><TextBlock x:Name="HealthText" Margin="8" TextWrapping="Wrap"/></GroupBox>
              </Grid>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Tune">
          <Grid Margin="18">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="470"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
              <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <StackPanel><TextBlock Text="Choose exact changes" FontSize="26" FontWeight="Bold"/><TextBlock Text="Supported controls remain visible even when already configured. Diagnostic findings are read-only." Foreground="{StaticResource Muted}" Margin="0,5,0,0" TextWrapping="Wrap"/></StackPanel>
              <ComboBox x:Name="CategoryFilter" Grid.Column="1" Width="170" VerticalAlignment="Bottom" SelectionChanged="CategoryFilter_SelectionChanged"><ComboBoxItem Content="All" IsSelected="True"/><ComboBoxItem Content="Windows Gaming"/><ComboBoxItem Content="Graphics"/><ComboBoxItem Content="Health"/><ComboBoxItem Content="Devices"/></ComboBox>
            </Grid>
            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#0D1724" CornerRadius="9" Padding="10" Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal"><TextBlock Text="QUICK PROFILES" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="4,0,10,0"/><Button Content="Safe Gaming Baseline" Click="SafeGamingProfile_Click"/><Button Content="Stability Review" Click="StabilityProfile_Click"/><Button Content="Clear" Click="ClearSelection_Click"/></StackPanel>
            </Border>
            <Border Grid.Row="2" Grid.Column="0" Background="#090E16" CornerRadius="9" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
              <ListBox x:Name="RecommendationList" Background="Transparent" Foreground="White" BorderThickness="0" SelectionChanged="RecommendationList_SelectionChanged">
                <ListBox.ItemTemplate><DataTemplate><Border BorderBrush="#223149" BorderThickness="0,0,0,1" Padding="13"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" IsEnabled="{Binding CanApply}" VerticalAlignment="Top" Margin="0,4,11,0" Click="RecommendationCheckBox_Click"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap"/><TextBlock Text="{Binding Summary}" Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate>
              </ListBox>
            </Border>
            <Border Grid.Row="2" Grid.Column="1" Background="{StaticResource Surface2}" CornerRadius="9" Padding="20" Margin="16,0,0,0" BorderBrush="{StaticResource Stroke}" BorderThickness="1">
              <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel><TextBlock x:Name="RecommendationTitle" Text="Select a setting or finding" FontSize="25" FontWeight="Bold" TextWrapping="Wrap"/><TextBlock x:Name="RecommendationMeta" Foreground="#7EB8FF" Margin="0,6,0,16"/><Grid Margin="0,0,0,14"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Border Grid.Column="0" Background="#0C131D" CornerRadius="7" Padding="12" Margin="0,0,7,0"><StackPanel><TextBlock Text="CURRENT" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="CurrentStateText" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border><Border Grid.Column="1" Background="#0D2119" CornerRadius="7" Padding="12" Margin="7,0,0,0"><StackPanel><TextBlock Text="TARGET" Foreground="{StaticResource Green}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="TargetStateText" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border></Grid><TextBlock Text="WHY" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="WhyText" TextWrapping="Wrap" Margin="0,5,0,16"/><TextBlock Text="WHAT GPTOPT DOES" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="HowText" TextWrapping="Wrap" Margin="0,5,0,16"/><Border Background="#0C131D" CornerRadius="7" Padding="12"><TextBlock x:Name="SafetyText" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
            </Border>
            <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="SelectionCountText" Text="0 selected" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/><Button x:Name="ApplySelectedButton" Grid.Column="1" Content="Review &amp; Apply" Click="ApplySelected_Click" Style="{StaticResource PrimaryButton}" Padding="22,11"/></Grid>
          </Grid>
        </TabItem>

        <TabItem Header="Diagnose">
          <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="22">
            <TextBlock Text="Find the cause, not another tweak" FontSize="27" FontWeight="Bold"/>
            <TextBlock Text="Use targeted checks and focused Windows/vendor tools. GPTOPT interprets results instead of duplicating every utility." Foreground="{StaticResource Muted}" Margin="0,6,0,18" TextWrapping="Wrap"/>
            <UniformGrid Columns="3">
              <Button Style="{StaticResource CardButton}" Click="RunTargetedDiagnostics_Click"><StackPanel><TextBlock Text="Targeted diagnostics" FontSize="17" FontWeight="Bold"/><TextBlock Text="Problem devices, WHEA, display resets, storage, USB, crashes, and reboot sources." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Button>
              <Button Style="{StaticResource CardButton}" Click="OpenControllerCalibration_Click"><StackPanel><TextBlock Text="Controller test" FontSize="17" FontWeight="Bold"/><TextBlock Text="Inspect axes, centering, range, and button response through Windows joy.cpl." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Button>
              <Button Style="{StaticResource CardButton}" Click="CompareCaptures_Click"><StackPanel><TextBlock Text="Before / after comparison" FontSize="17" FontWeight="Bold"/><TextBlock Text="Compare frame-time exports and get a keep, rollback, or inconclusive result." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Button>
            </UniformGrid>
            <TextBlock Text="Open system tools" FontSize="20" FontWeight="Bold" Margin="0,22,0,10"/>
            <WrapPanel><Button Content="PresentMon" Width="165" Click="OpenPresentMon_Click"/><Button Content="Task Manager" Width="165" Click="OpenTaskManager_Click"/><Button Content="Device Manager" Width="165" Click="OpenDeviceManager_Click"/><Button Content="Event Viewer" Width="165" Click="OpenEventViewer_Click"/><Button Content="Windows Update" Width="165" Click="OpenWindowsUpdate_Click"/><Button Content="NVIDIA App" Width="165" Click="OpenNvidiaApp_Click"/></WrapPanel>
          </StackPanel></ScrollViewer>
        </TabItem>

        <TabItem Header="History">
          <Grid Margin="20"><Grid.ColumnDefinitions><ColumnDefinition Width="380"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><ListBox x:Name="HistoryList" Grid.Column="0" Background="#090E16" Foreground="White" BorderBrush="{StaticResource Stroke}" MouseDoubleClick="HistoryList_MouseDoubleClick"/><StackPanel Grid.Column="1" Margin="22,0,0,0"><TextBlock Text="Audit and rollback history" FontSize="26" FontWeight="Bold"/><TextBlock Text="Double-click an audit to open its private local folder. Published GitHub summaries can lag until Scan + Publish is used." TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,8,0,18"/><Button Content="Open Audit Store" HorizontalAlignment="Left" Click="OpenAuditStore_Click"/><Button Content="Open Rollback Manager" HorizontalAlignment="Left" Click="OpenRollbackManager_Click"/></StackPanel></Grid>
        </TabItem>
      </TabControl>
    </Grid>

    <Border Grid.Row="2" Background="#0B111B" BorderBrush="#1C2A3C" BorderThickness="0,1,0,0" Padding="18,12">
      <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="240"/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="StatusText" Text="Ready" Foreground="#C2CDDA" TextWrapping="Wrap"/><TextBlock x:Name="StatusDetailText" Text="No task running" Foreground="#68798F" FontSize="11" Margin="0,3,0,0"/></StackPanel><ProgressBar x:Name="AuditProgress" Grid.Column="1" Height="8" Minimum="0" Maximum="100" VerticalAlignment="Center"/></Grid>
    </Border>
  </Grid>
</Window>