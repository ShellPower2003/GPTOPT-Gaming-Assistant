<Window x:Class="GPTOPT.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPTOPT Gaming Assistant" Width="1320" Height="860"
        MinWidth="1120" MinHeight="720" WindowStartupLocation="CenterScreen"
        Background="#090D14" Foreground="#F4F7FB">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#111824"/>
    <SolidColorBrush x:Key="CardBrush" Color="#151E2C"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#93A2B7"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#5EA1FF"/>
    <Style TargetType="Button">
      <Setter Property="Background" Value="#1C2A3D"/><Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#31445F"/><Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,9"/><Setter Property="Margin" Value="4"/><Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="#B9C5D6"/><Setter Property="Padding" Value="18,11"/>
    </Style>
    <Style TargetType="GroupBox">
      <Setter Property="Background" Value="{StaticResource CardBrush}"/><Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#263347"/><Setter Property="Padding" Value="10"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#0D1420" BorderBrush="#1E2A3A" BorderThickness="0,0,0,1" Padding="22,16">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="GPTOPT" FontSize="30" FontWeight="Bold"/>
            <Border Background="#17345A" CornerRadius="12" Padding="9,3" Margin="12,5,0,0"><TextBlock Text="NATIVE PREVIEW" Foreground="#8FC1FF" FontSize="11" FontWeight="SemiBold"/></Border>
          </StackPanel>
          <TextBlock Text="Check your PC, understand every recommendation, apply selected changes, then verify the result." Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="LocalAuditButton" Content="Check PC" Click="LocalAuditButton_Click"/>
          <Button x:Name="PublishAuditButton" Content="Check + Publish" Click="PublishAuditButton_Click"/>
          <Button Content="Refresh" Click="RefreshButton_Click"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="18">
      <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="16" Margin="0,0,16,0">
        <StackPanel>
          <TextBlock Text="SYSTEM STATUS" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold"/>
          <Border Background="#0D1420" CornerRadius="9" Padding="14" Margin="0,10,0,18">
            <StackPanel>
              <TextBlock x:Name="HealthGradeText" Text="--" FontSize="38" FontWeight="Bold" Foreground="#73D6A0"/>
              <TextBlock x:Name="HealthSummaryText" Text="Run an audit to calculate status" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <TextBlock Text="GUIDED FLOW" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold"/>
          <Border Background="#16253A" CornerRadius="8" Padding="12" Margin="0,10,0,6"><StackPanel><TextBlock Text="1  CHECK" FontWeight="Bold" Foreground="#8FC1FF"/><TextBlock Text="Collect current system state" Foreground="{StaticResource MutedBrush}" FontSize="12"/></StackPanel></Border>
          <Border Background="#141C29" CornerRadius="8" Padding="12" Margin="0,0,0,6"><StackPanel><TextBlock Text="2  OPTIMIZE" FontWeight="Bold"/><TextBlock Text="Choose explained actions" Foreground="{StaticResource MutedBrush}" FontSize="12"/></StackPanel></Border>
          <Border Background="#141C29" CornerRadius="8" Padding="12" Margin="0,0,0,18"><StackPanel><TextBlock Text="3  VERIFY" FontWeight="Bold"/><TextBlock Text="Re-audit and compare" Foreground="{StaticResource MutedBrush}" FontSize="12"/></StackPanel></Border>

          <TextBlock Text="LATEST AUDIT" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold"/>
          <TextBlock x:Name="AuditIdText" Text="No audit loaded" TextWrapping="Wrap" Margin="0,8,0,16"/>
          <Button Content="Verify Changes" Click="VerifyChanges_Click" HorizontalAlignment="Stretch"/>
          <Button Content="Open Rollback Folder" Click="OpenRollbackFolder_Click" HorizontalAlignment="Stretch"/>
        </StackPanel>
      </Border>

      <TabControl Grid.Column="1" Background="{StaticResource PanelBrush}" BorderThickness="0">
        <TabItem Header="Optimize">
          <Grid Margin="18">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="470"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14">
              <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="Recommended actions" FontSize="25" FontWeight="Bold"/>
                <TextBlock Text="Every option explains the benefit, risk, exact change, admin requirement, and reboot requirement." Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <TextBlock Text="Category" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CategoryFilter" Width="160" SelectionChanged="CategoryFilter_SelectionChanged">
                  <ComboBoxItem Content="All" IsSelected="True"/><ComboBoxItem Content="Windows Gaming"/><ComboBoxItem Content="Graphics"/><ComboBoxItem Content="Health"/><ComboBoxItem Content="Devices"/>
                </ComboBox>
              </StackPanel>
            </Grid>

            <Border Grid.Row="1" Grid.Column="0" Background="#0B111B" CornerRadius="8" BorderBrush="#263347" BorderThickness="1">
              <ListBox x:Name="RecommendationList" Background="Transparent" Foreground="White" BorderThickness="0" SelectionChanged="RecommendationList_SelectionChanged">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#243044" BorderThickness="0,0,0,1" Padding="12">
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" IsEnabled="{Binding CanApply}" VerticalAlignment="Top" Margin="0,3,10,0" Click="RecommendationCheckBox_Click"/>
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                          <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Border Background="#17345A" CornerRadius="9" Padding="7,2" Margin="0,0,6,0"><TextBlock Text="{Binding Category}" Foreground="#8FC1FF" FontSize="10"/></Border>
                            <Border Background="#273323" CornerRadius="9" Padding="7,2" Margin="0,0,6,0"><TextBlock Text="{Binding ExpectedImpact}" Foreground="#A9D99C" FontSize="10"/></Border>
                            <Border Background="#39252A" CornerRadius="9" Padding="7,2"><TextBlock Text="{Binding Risk}" Foreground="#FFB5B5" FontSize="10"/></Border>
                          </StackPanel>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="20" Margin="16,0,0,0" BorderBrush="#263347" BorderThickness="1">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                  <TextBlock x:Name="RecommendationTitle" Text="Select a recommendation" FontSize="25" FontWeight="Bold" TextWrapping="Wrap"/>
                  <TextBlock x:Name="RecommendationMeta" Foreground="#8FC1FF" Margin="0,6,0,16"/>
                  <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#101722" CornerRadius="7" Padding="12" Margin="0,0,7,0"><StackPanel><TextBlock Text="CURRENT" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="CurrentStateText" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border>
                    <Border Grid.Column="1" Background="#102019" CornerRadius="7" Padding="12" Margin="7,0,0,0"><StackPanel><TextBlock Text="TARGET" Foreground="#79D6A0" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="TargetStateText" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border>
                  </Grid>
                  <TextBlock Text="WHY THIS MATTERS" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold"/>
                  <TextBlock x:Name="WhyText" TextWrapping="Wrap" Margin="0,5,0,16" Foreground="#DDE4EE"/>
                  <TextBlock Text="EXACT CHANGE" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="Bold"/>
                  <TextBlock x:Name="HowText" TextWrapping="Wrap" Margin="0,5,0,16" Foreground="#DDE4EE"/>
                  <Border Background="#101722" CornerRadius="7" Padding="12"><TextBlock x:Name="SafetyText" TextWrapping="Wrap"/></Border>
                </StackPanel>
              </ScrollViewer>
            </Border>

            <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,14,0,0">
              <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <Button Content="Select Safe Defaults" Click="SelectSafeDefaults_Click"/>
                <Button Content="Clear" Click="ClearSelection_Click"/>
                <TextBlock x:Name="SelectionCountText" Text="0 selected" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource MutedBrush}"/>
              </StackPanel>
              <Button x:Name="ApplySelectedButton" Grid.Column="1" Content="Review & Apply Selected" Click="ApplySelected_Click" Background="#1D5FAE" BorderBrush="#4B90E6" Padding="20,10"/>
            </Grid>
          </Grid>
        </TabItem>

        <TabItem Header="Dashboard">
          <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="18">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <GroupBox Header="Platform" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"><TextBlock x:Name="PlatformText" Margin="8" TextWrapping="Wrap"/></GroupBox>
            <GroupBox Header="Gaming Configuration" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8"><TextBlock x:Name="GamingText" Margin="8" TextWrapping="Wrap"/></GroupBox>
            <GroupBox Header="Devices and Running Tools" Grid.Row="1" Grid.Column="0" Margin="0,8,8,0"><TextBlock x:Name="DeviceText" Margin="8" TextWrapping="Wrap"/></GroupBox>
            <GroupBox Header="Health Signals" Grid.Row="1" Grid.Column="1" Margin="8,8,0,0"><TextBlock x:Name="HealthText" Margin="8" TextWrapping="Wrap"/></GroupBox>
          </Grid></ScrollViewer>
        </TabItem>

        <TabItem Header="Audit History">
          <Grid Margin="18"><Grid.ColumnDefinitions><ColumnDefinition Width="350"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <ListBox x:Name="HistoryList" Grid.Column="0" Background="#0B111B" Foreground="White" MouseDoubleClick="HistoryList_MouseDoubleClick"/>
            <StackPanel Grid.Column="1" Margin="20,0,0,0">
              <TextBlock Text="Persistent local audit history" FontSize="24" FontWeight="Bold"/>
              <TextBlock Text="Double-click an audit to open its folder. Raw details remain local; only sanitized summaries are published." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,16"/>
              <Button Content="Open Audit Store" HorizontalAlignment="Left" Click="OpenAuditStore_Click"/>
            </StackPanel>
          </Grid>
        </TabItem>

        <TabItem Header="Performance">
          <StackPanel Margin="24">
            <TextBlock Text="Measure before and after" FontSize="25" FontWeight="Bold"/>
            <TextBlock Text="GPTOPT should verify changes with frame-time and latency data instead of assuming they helped. PresentMon integration is the measurement layer." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,18"/>
            <Button Content="Open PresentMon" Width="180" HorizontalAlignment="Left" Click="OpenPresentMon_Click"/>
          </StackPanel>
        </TabItem>
      </TabControl>
    </Grid>

    <Border Grid.Row="2" Background="#0D1420" BorderBrush="#1E2A3A" BorderThickness="0,1,0,0" Padding="18,12">
      <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
        <StackPanel><TextBlock x:Name="StatusText" Text="Ready" Foreground="#B9C5D6" TextWrapping="Wrap"/><TextBlock x:Name="StatusDetailText" Text="No task running" Foreground="#68798F" FontSize="11" Margin="0,3,0,0"/></StackPanel>
        <ProgressBar x:Name="AuditProgress" Grid.Column="1" Height="8" Minimum="0" Maximum="100" VerticalAlignment="Center"/>
      </Grid>
    </Border>
  </Grid>
</Window>